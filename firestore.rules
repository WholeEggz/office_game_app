rules_version = '2';

// The redaction architecture from implementation_plan.md's "highest-risk
// technical piece" section: Firestore rules are a binary allow/deny on a
// whole document, not a per-viewer field transform, so LocalGameRepository's
// per-viewer role redaction (_publicView/_visiblePlayers) is reproduced as
// three separate collections instead of one:
//   - players/{playerId}      the true doc — self-only, Cloud Functions write
//   - publicPlayers/{playerId} a redacted mirror kept in sync by a trigger
//   - cellViews/{viewerId}     the viewer's own cell-link role reveals
//
// All writes everywhere below are Cloud-Functions-only: the Admin SDK
// bypasses these rules entirely, so `allow write: if false` blocks direct
// client writes without blocking the functions that actually mutate state.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(playerId) {
      return isSignedIn() && request.auth.uid == playerId;
    }

    function isMember(gameId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid));
    }

    function isCurrentMafia(gameId) {
      let doc = get(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid));
      return isSignedIn() && doc.data.role == 'mafia' && doc.data.wasUnmasked == false;
    }

    match /games/{gameId} {
      // Browsable by any signed-in user, even before joining — the doc's
      // own fields are already public-by-design (concept doc §6: the
      // elimination/recruitment method/sign forewarnings are method-only,
      // never-the-target), so no redaction is needed here.
      allow read: if isSignedIn();
      allow write: if false;

      match /players/{playerId} {
        allow read: if isSelf(playerId);
        allow write: if false;
      }

      match /passphrase/{doc} {
        // A restricted case's actual passphrase — client-readable only by
        // the case's own creator (its admin), who can look it back up to
        // repeat it to a coworker after the one-time reveal at creation.
        // Anyone else browsing "Find your case" still can't read this, so
        // the point of marking a case restricted holds for everyone but
        // the person who set it. addPlayer/verifyCasePassphrase (Admin SDK
        // bypass) remain the only things that check it against a guess.
        allow read: if isSignedIn() &&
          get(/databases/$(database)/documents/games/$(gameId)).data.creatorId == request.auth.uid;
        allow write: if false;
      }

      match /publicPlayers/{playerId} {
        // Deliberately not membership-gated, unlike the other subcollections
        // below: CaseDetailsScreen shows a game's roster before joining
        // (PlayerEntryScreen -> "find your case" -> case details), and this
        // is safe to leave open because it's already the redacted view —
        // role forced to villager and vote weight forced to the starting
        // value unless the player was actually unmasked. No membership
        // check is needed to protect something that's already public.
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /cellViews/{viewerId} {
        // Genuinely sensitive — reveals real roles behind a viewer's own
        // cell-structure links (design pillar #4) — so unlike publicPlayers
        // this is strictly self-only.
        allow read: if isSelf(viewerId);
        allow write: if false;
      }

      match /mafiaThread/{entryId} {
        // A binary gate a rule *can* express directly, unlike per-viewer
        // redaction: mafia or not, checked against the requester's own true
        // player doc. An unmasked member loses this the instant they flip.
        allow read: if isCurrentMafia(gameId);
        allow write: if false;
      }

      match /votes/{voteId} {
        // Not secret per the concept doc — voting history is permanent and
        // visible to everyone in the game — just member-gated, not redacted.
        allow read: if isMember(gameId);
        allow write: if false;
      }

      match /observations/{observationId} {
        // Ephemeral (purged after 3 rounds by a scheduled function, not
        // just filtered on read) but not role-gated — same member-only
        // treatment as votes.
        allow read: if isMember(gameId);
        allow write: if false;
      }

      match /moments/{momentId} {
        // Per-player notification bookkeeping, not contested game state —
        // per implementation_plan.md's Cloud Functions inventory, "a rule
        // of playerId == request.auth.uid is sufficient." Unlike every
        // other subcollection above, this allows a *client* write: a
        // player acknowledging their own moments (acknowledgeAllMoments)
        // or recording their own reentry (recordReentry) doesn't decide
        // any game truth, so it doesn't need to go through a Cloud
        // Function the way vote/role/weight changes do. Game-truth
        // functions (round resolution, elimination, recruitment, finale)
        // still write moments too, via the Admin SDK bypass, same as
        // everywhere else.
        allow read: if isSelf(resource.data.playerId);
        allow create: if isSelf(request.resource.data.playerId);
        allow update: if isSelf(resource.data.playerId);
        allow delete: if false;
      }

      match /debugRoster/{playerId} {
        // The debug role switcher's full-roster view (real roles) has no
        // safe general answer under this redaction architecture — so
        // unlike every other collection here, this one's *write* side
        // (the syncPlayerViews trigger, see functions/index.js) is gated
        // to only fire when FUNCTIONS_EMULATOR is set, never in a real
        // deployment. That's what actually protects this: in production
        // the collection is simply never populated, so gating the read
        // side at all is defense in depth, not the primary control — same
        // reasoning as publicPlayers below. Deliberately not member-gated
        // (unlike this reasoning's first draft): the tester operating the
        // role switcher is a separate identity from every minted
        // quick-start player (registerNewPlayer never switches the
        // current session, matching LocalAuthService), so they're never
        // actually a member of the game whose roster they need to see.
        // Don't reuse this collection for anything the write-gate doesn't
        // cover.
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /reports/{reportId} {
        // Written only by the reportPlayer Cloud Function (Admin SDK
        // bypass) — never client-readable at all, unlike every other
        // collection above: reporting someone shouldn't let them (or
        // anyone else) see it, and there's no in-app moderator view to
        // grant read access to (reviewed externally).
        allow read: if false;
        allow write: if false;
      }

      match /blocks/{viewerId} {
        // A player's own preference (which other players' observations
        // to hide from themselves), not game truth — same reasoning as
        // moments above: doesn't decide anything about the game itself,
        // so a direct client write is safe. Unlike moments, this is
        // client-only in both directions; no Cloud Function ever writes
        // it.
        allow read: if isSelf(viewerId);
        allow write: if isSelf(viewerId);
      }

      match /dismissedHints/{viewerId} {
        // Mirrors `blocks` above exactly: a player's own tutorial-hint
        // dismissals, not game truth, client-only in both directions.
        allow read: if isSelf(viewerId);
        allow write: if isSelf(viewerId);
      }
    }

    match /users/{userId} {
      // This device's persisted display name (FirebaseAuthService),
      // recovered by resumeSession() on a later app launch since Firebase
      // Auth's own displayName field can't be used (see that class's doc
      // comment). Not game truth, purely this device's own profile fact,
      // so client read/write is safe — same reasoning as `blocks`. The
      // country/city/companyOrOffice fields saveLocationProfile also
      // writes here ride along under this same rule — still just this
      // device's own profile facts.
      allow read: if isSelf(userId);
      allow write: if isSelf(userId);
    }

    // Deduped autocomplete sources for registration's location fields —
    // {display, count} keyed by the normalized (trim+lowercase) value as
    // the doc id itself, so "Acme Corp"/"ACME"/"acme corp." converge on
    // one doc instead of fragmenting. Shared, cross-user reference data
    // (not a secret, not game truth), so any signed-in user can read it
    // for their own typeahead — same openness as `publicPlayers`. Writes
    // only ever come from saveLocationProfile (Admin SDK bypass): a
    // client incrementing a shared counter directly isn't something
    // these rules can safely allow.
    match /locations_countries/{value} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /locations_cities/{value} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /locations_companies/{value} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
