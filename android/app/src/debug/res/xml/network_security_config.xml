<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only: the Firebase Local Emulator Suite (see main.dart's
     _useFirebaseEmulators) is reached over plain http://, which Android
     blocks by default since API 28 — without this, every Firebase SDK
     call to the emulator fails with a generic "cleartext HTTP traffic
     to 10.0.2.2 not permitted" error. 10.0.2.2 is the Android emulator's
     documented alias for the host machine's localhost. This file only
     exists in the debug source set, so it never ships in a release
     build. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
